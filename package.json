{
  "name": "wittallen-net",
  "version": "1.1.0",
  "description": "Planning to use 11ty and TailwindCSS to make a pretty, FAST site that isn't a pain to manage or update.\r 🤞",
  "main": "index.js",
  "scripts": {
    "dev": "Remove-Item -recurse -force _site && mkdir _site && postcss _includes/style.css > _site/style.css && eleventy --serve --quiet",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "Remove-Item -recurse -force _site && eleventy && NODE_ENV=production postcss _includes/style.css > _site/style.css",
    "serve": "npx @11ty/eleventy --serve",
    "start": "npx @11ty/eleventy --serve"
  },
  "keywords": [],
  "author": "Witt Allen @wittionary",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0"
  },
  "dependencies": {
    "autoprefixer": "^10.4.14",
    "cssnano": "^6.0.1",
    "html-minifier": "^4.0.0",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-footnote": "^3.0.3",
    "postcss": "^8.4.27",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.3.3"
  }
}
